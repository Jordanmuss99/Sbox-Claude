{
  "name": "sbox-mcp-server",
  "version": "1.5.0",
  "description": "MCP Server for s&box game engine — enables Claude to build games through conversation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sbox-mcp-server": "dist/index.js",
    "sbox-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:aliases": "node scripts/smoke-aliases.mjs",
    "sync-addon": "node -e \"console.log('Use scripts/sync-addon.ps1 (Windows) or scripts/sync-addon.sh (POSIX) with a -Target / argument.')\"",
    "verify-addon-sync": "node scripts/verify-addon-sync.mjs",
    "docs:gen-status": "node scripts/gen-status.mjs",
    "docs:inject-status": "node scripts/inject-status.mjs",
    "docs:sync": "npm run docs:gen-status && node scripts/inject-status.mjs --write",
    "docs:check": "npm run docs:gen-status && node scripts/inject-status.mjs"
  },
  "keywords": [
    "mcp",
    "sbox",
    "s&box",
    "game-engine",
    "claude",
    "ai",
    "source2",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lousputthole/sbox-claude"
  },
  "author": "sboxskins.gg (https://sboxskins.gg)",
  "homepage": "https://sboxskins.gg",
  "bugs": {
    "url": "https://github.com/lousputthole/sbox-claude/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "GPL-3.0-or-later"
}
